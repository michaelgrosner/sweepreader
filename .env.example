# Copy to .env and fill in values, then: set -a && source .env && set +a
# .env is gitignored — never commit real keys

# LLM (required for classification; without it, keyword fallback is used)
OPENROUTER_API_KEY=sk-or-...

# SMTP — the dedicated Gmail account sends, SMTP_TO is where you receive the digest
SMTP_HOST=smtp.gmail.com
SMTP_USER=yourname.sweepreader@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # App Password from the dedicated account
SMTP_TO=your.personal.email@example.com    # your personal email

# IMAP — same dedicated Gmail account, same (or a second) App Password
IMAP_HOST=imap.gmail.com
IMAP_USER=yourname.sweepreader@gmail.com
IMAP_PASSWORD=xxxx xxxx xxxx xxxx   # can be same App Password as SMTP_PASSWORD
